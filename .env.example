# MySQL connection (server-only; never prefix these with NEXT_PUBLIC_)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=project_helps
DB_USER=project_helps_app
DB_PASSWORD=replace-with-database-password
DB_SSL=false

# Primary administrator bootstrap (server-only)
ADMIN_USERNAME=administrator
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_EMAIL=administrator@example.gov.ph
ADMIN_DELETE_PIN=replace-with-a-private-pin
